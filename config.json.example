{
    "host":  "127.0.0.1",
    "port":  8000,
    "cors_origins":  [
                         "http://localhost",
                         "http://ivy.local"
                     ],
    "jwt_secret":  "change_me",
    "log_rotate_mb":  100,
    "log_retention_days":  14,
    "allowlist_domains":  [
                              "open-meteo.com",
                              "duckduckgo.com"
                          ],
    "allowlist_ports":  [
                            80,
                            443
                        ],
    "db_path":  "app/data/history.db",
    "rag_inbox_dir":  "app/data/inbox",
    "rag_knowledge_dir":  "app/data/knowledge",
    "rag_index_dir":  "app/data/faiss_index",
    "rag_enable_ocr":  true,
    "rag_ocr_lang":  "fra+eng",
    "rag_chunk_size":  1000,
    "rag_chunk_overlap":  200,
    "rag_reindex_interval_minutes":  60,
    "rag_watchers_enabled":  true,
    "rag_reindex_enabled":  true,
    "history_retention_days":  30,
    "history_max_mb":  200,
    "mask_secrets_patterns":  "api_key,token,authorization,password",
    "ws_heartbeat_sec":  15,
    "ws_auth_required":  false,
    "chat_system_prompt":  "Tu es IVY, assistant local francophone, synthetique et fiable. Tu cites tes sources quand elles proviennent d\u0027Internet.",
    "chat_history_max_messages":  12,
    "qa_similarity_threshold":  0.92,
    "embedding_model_name":  "sentence-transformers/all-MiniLM-L6-v2",
    "duckduckgo_safe_search":  "moderate",
    "duckduckgo_region":  "wt-wt",
    "duckduckgo_max_results":  5,
    "llm_provider":  "llama_cpp",
    "llm_model_path":  "models/Meta-Llama-3.1-8B-Instruct-Q5_K_M.gguf",
    "llm_max_output_tokens":  768,
    "llm_temperature":  0.7,
    "llm_context_tokens":  8192,
    "llm_n_gpu_layers":  0,
    "tensorrt_llm_base_url":  "http://127.0.0.1:8000",
    "tensorrt_llm_chat_endpoint":  "/v1/chat/completions",
    "tensorrt_llm_model":  "meta/llama-3.1-8b-instruct",
    "tensorrt_llm_api_key":  null,
    "tensorrt_llm_extra_headers":  {

                                   },
    "scheduler_tz":  "Europe/Paris",
    "enable_metrics":  false,
    "rate_limit_rps":  10,
    "reset_admin_flag":  "app/data/reset_admin.flag",
    "cookie_secure":  false,
    "cookie_samesite":  "lax",
    "csrf_max_age_seconds":  3600,
    "jeedom_base_url":  null,
    "jeedom_api_key":  null,
    "disable_auth":  false
}
